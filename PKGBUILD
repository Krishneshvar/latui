pkgname=latui
pkgver=1.1.0
pkgrel=1
pkgdesc="A TUI-based multi-purpose launcher"
url="https://github.com/Krishneshvar/latui"
license=("GPL-3.0-only")
arch=("x86_64")
depends=("sqlite")
source=("https://github.com/Krishneshvar/latui/releases/download/v$pkgver/latui-$pkgver-x86_64.tar.gz")
sha256sums=('08053f9e2de7a08370a1c326202b970fdf7e322fa80659c2dda7e985cbb0026e')

package() {
    install -Dm755 latui -t "$pkgdir/usr/bin"

    install -Dm644 latui.desktop -t "$pkgdir/usr/share/applications"

    install -Dm644 assets/latui.svg -t "$pkgdir/usr/share/icons/hicolor/scalable/apps"

    install -Dm644 assets/latui.png -t "$pkgdir/usr/share/icons/hicolor/512x512/apps"
    
    install -Dm644 LICENSE -t "$pkgdir/usr/share/licenses/$pkgname"
}
